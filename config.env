###############################################################################
# Twilight E-Commerce Platform Configuration
###############################################################################

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost

# Database Configuration
DB_NAME=twilight.db
DB_PATH=database/twilight.db

# Session Configuration
SESSION_TIMEOUT=86400  # 24 hours in seconds
SESSION_DIR=sessions

# Security Configuration
PASSWORD_MIN_LENGTH=6
USERNAME_MIN_LENGTH=3
USERNAME_MAX_LENGTH=20

# File Upload Configuration
MAX_IMAGE_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_TYPES="jpg jpeg png gif"

# Email Configuration (for future implementation)
SMTP_HOST=localhost
SMTP_PORT=587
FROM_EMAIL=noreply@twilight.com

# Application Settings
APP_NAME="Twilight"
APP_DESCRIPTION="Handmade Treasures for Every Woman"
APP_VERSION="1.0.0"

# Admin Default Credentials (Change these after first login!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@twilight.com

# Logging
LOG_FILE=twilight.log
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Pagination
PRODUCTS_PER_PAGE=12
ORDERS_PER_PAGE=20

# Categories
PRODUCT_CATEGORIES="Accessories,Home Decor,Bags,Textiles,Jewelry,Storage,Home & Kitchen,Stationery"

# Order Status
ORDER_STATUSES="pending,processing,shipped,delivered,cancelled"

# Payment Methods (for future implementation)
PAYMENT_METHODS="cod,card,paypal"

# Currency
CURRENCY_SYMBOL="$"
CURRENCY_CODE="USD"

# Timezone
TIMEZONE="America/New_York"

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We are currently performing maintenance. Please check back soon!"
